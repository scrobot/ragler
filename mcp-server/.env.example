# KMS-RAG Backend API Configuration
KMS_API_URL=http://localhost:3000

# MCP Server Identity (sent as headers to backend)
MCP_USER_ID=mcp-server
MCP_USER_ROLE=DEV

# Transport: stdio | streamable-http | sse (default: stdio)
TRANSPORT=stdio

# HTTP listen port (used when TRANSPORT is streamable-http or sse)
PORT=3100

# Future: API Key (not currently used by backend)
KMS_API_KEY=
